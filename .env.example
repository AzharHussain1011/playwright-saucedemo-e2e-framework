# Environment Configuration Template
# Copy this to .env file and fill in your settings

# Base URL for the application
BASE_URL=https://www.saucedemo.com/

# Browser settings
BROWSER=chromium
# Options: chromium, firefox, webkit
HEADLESS=true

# Viewport settings
VIEWPORT_WIDTH=1920
VIEWPORT_HEIGHT=1080

# Timeout settings (in milliseconds)
PAGE_TIMEOUT=30000
ACTION_TIMEOUT=10000
WAIT_TIMEOUT=5000
EXPECT_TIMEOUT=5000

# Retry settings
MAX_RETRIES=2
RETRY_DELAY=1000

# Parallel workers
# Leave empty for auto, set to 1 for serial execution
WORKERS=

# Reporting
HTML_REPORT=true
JSON_REPORT=true
JUNIT_REPORT=true

# Screenshots
SCREENSHOT_ON_FAILURE=true
SCREENSHOT_ON_SUCCESS=false

# Video recording
VIDEO_ON_FAILURE=true

# Trace files
TRACE_ON_FAILURE=true

# Logging
LOGGING_ENABLED=true
LOG_LEVEL=info
# Options: debug, info, warn, error

# Environment selection
ENV=dev
# Options: dev, staging, prod

# API Configuration (if needed)
API_BASE_URL=https://api.saucedemo.com/
API_TIMEOUT=10000

# Security
IGNORE_HTTPS=true
